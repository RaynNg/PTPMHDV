{
  "id": null,
  "uid": "demo-overview",
  "title": "Microservice Observability Overview",
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "5s",
  "tags": ["demo", "otel"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "label": "Service",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(target_info, service_name)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Checkout Throughput (req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(demo_checkout_requests_total{service_name=~\"$service\"}[1m])) by (service_name, status)",
          "legendFormat": "{{service_name}} - {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Checkout Latency p95 (ms)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(demo_checkout_duration_ms_bucket{service_name=~\"$service\"}[1m])) by (le, service_name))",
          "legendFormat": "{{service_name}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Orders Created (req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(demo_orders_created_total{service_name=~\"$service\"}[1m])) by (service_name)",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inventory Reserve Failures (req/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(demo_inventory_reserve_fail_total{service_name=~\"$service\"}[1m])) by (service_name, reason)",
          "legendFormat": "{{service_name}} - {{reason}}",
          "refId": "A"
        }
      ]
    }
  ]
}
